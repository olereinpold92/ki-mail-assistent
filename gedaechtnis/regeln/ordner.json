{
  "version": "1.0",
  "beschreibung": "Regeln fuer die Zuordnung von Mails zu Outlook-Ordnern",
  "standard_ordner": "Posteingang",
  "regeln": [
    {
      "wenn": "Absender enthaelt 'atos' oder Betreff enthaelt 'ATOS'",
      "dann": "Firmen & Organisationen / ATOS",
      "konfidenz": 0.9,
      "quelle": "outlook_ordnerstruktur"
    },
    {
      "wenn": "Absender enthaelt 'helios'",
      "dann": "Firmen & Organisationen / Helios",
      "konfidenz": 0.9,
      "quelle": "outlook_ordnerstruktur"
    },
    {
      "wenn": "Absender enthaelt 'stepstone' oder 'indeed' oder Betreff enthaelt 'Bewerbung'",
      "dann": "Personal / Bewerbungen",
      "konfidenz": 0.8,
      "quelle": "outlook_ordnerstruktur"
    },
    {
      "wenn": "Mail ist eine Rechnung oder enthaelt Rechnungsanhang",
      "dann": "Finanzbuchhaltung",
      "konfidenz": 0.7,
      "quelle": "vermutung"
    }
  ],
